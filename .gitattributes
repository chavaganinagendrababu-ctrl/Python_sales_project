# Git Attributes Configuration
# Ensure consistent line endings across platforms

# Auto detect text files and normalize line endings to LF
* text=auto

# Python files
*.py text eol=lf
*.pyw text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Markdown
*.md text eol=lf
*.markdown text eol=lf

# JSON
*.json text eol=lf
*.jsonld text eol=lf

# YAML
*.yaml text eol=lf
*.yml text eol=lf

# CSV
*.csv text eol=lf

# Documentation
*.txt text eol=lf
LICENSE text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.zip binary
*.gz binary
*.tar binary
